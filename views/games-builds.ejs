<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <% function formatGame(slug){ return String(slug||'').split('-').filter(Boolean).map(s=>s.charAt(0).toUpperCase()+s.slice(1)).join(' ');} %>
    <title>Builds - <%= formatGame(gameSlug) %></title>

    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/builds.css">
</head>
<body class="builds-body">

    <header class="site-header" role="banner">
        <header class="site-header" role="banner">
            <div class="site-header-inner">
                <a class="logo" href="/">ELDEN SCRIPTORIUM</a>

                <a class="user-area" href="/auth" aria-label="Ir a autenticación">
                    <div class="user-avatar" aria-hidden="false"><%= (user && user.username) ? String(user.username).charAt(0).toUpperCase() : 'U' %></div>
                </a>
            </div>
        </header>

        <div class="header-separator" aria-hidden="true"></div>

        <div class="page-hero">
                <div class="page-hero-inner">
                    <div class="hero-header-row">
                        <div class="hero-left"></div>
                        <h1 class="builds-title"><%= formatGame(gameSlug) %></h1>
                        <div class="hero-controls">
                            <input id="builds-search" class="search-input" type="search" placeholder="Buscar builds..." aria-label="Buscar builds">
                            <label for="builds-order" class="visually-hidden">Orden</label>
                            <select id="builds-order">
                                <option value="yours">Tuyas primero</option>
                                <option value="recent">Recientes</option>
                                <option value="top">Más votadas</option>
                            </select>
                        </div>
                    </div>

                    <div class="create-build-row">
                        <a class="btn btn-primary create-build-btn" href="/<%= encodeURIComponent(gameSlug || '') %>/builder">Nueva build</a>
                    </div>
                    <!-- Featured builds row for the selected game -->
                    <div id="featured-builds" class="featured-row" aria-live="polite">
                        <!-- Client will inject small build cards here -->
                    </div>
                </div>
        </div>

    <main class="builds-container">

        <section class="builds-topbar">
            <h2 class="builds-section-title">Selecciona tu build</h2>
        </section>

        <section id="builds-list" class="builds-list">
        </section>
    </main>

    <script id="initial-data" type="application/json">
        <%- JSON.stringify({ gameSlug: gameSlug || '', user: user || null }) %>
    </script>

    <script type="module" src="/scripts/builds.client.js"></script>
</body>
</html>