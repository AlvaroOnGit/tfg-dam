<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Settings | Elden Scriptorium</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0">
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/account-settings.css">
</head>
<body>
    <div class="page-bg"></div>

    <header class="topbar">
        <a class="brand" href="/">ELDEN SCRIPTORIUM</a>
        <nav class="top-nav">
            <a href="#">Builds</a>
            <a href="#">Lore</a>
            <a href="#">Grimoire</a>
            <a href="#">Almanac</a>
        </nav>
        <button class="icon-button" aria-label="Open user menu">
            <span class="material-symbols-outlined">account_circle</span>
        </button>
    </header>

    <main class="settings-shell">
        <p class="kicker">SANCTUM ACCESS</p>
        <h1>User Settings</h1>
        <p class="intro">
            Modify your presence within the Scriptorium. Ensure your credentials remain arcane and secure.
        </p>

        <section class="settings-grid">
            <aside class="profile-panel">
                <div class="avatar-wrap">
                    <img src="/media/default-avatar.png" alt="User avatar" onerror="this.style.display='none'; this.parentElement.classList.add('avatar-fallback');">
                    <span class="avatar-placeholder">A</span>
                </div>

                <p class="quick-actions">Quick Actions</p>
                <button class="panel-link" id="quick-change-password" type="button">Change Password</button>
            </aside>

            <section class="form-panel">
                <form class="settings-form" id="user-settings-form">
                    <p id="settings-message" class="form-message" aria-live="polite"></p>

                    <section class="form-section">
                        <p class="section-title">Public Information</p>
                        <label for="username">Username</label>
                        <input id="username" name="username" type="text" value="TAR_MAGE_99" autocomplete="username">
                        <p class="field-note">Changing this field requires current password.</p>
                    </section>

                    <section class="form-section">
                        <p class="section-title">Personal Information</p>
                        <label for="email">Email Address</label>
                        <input id="email" name="email" type="email" value="morgot.fell@leyndell.com" autocomplete="email">
                        <p class="field-note">Changing this field requires current password.</p>
                    </section>

                    <section class="form-section">
                        <p class="section-title">Password</p>
                        <label for="currentPassword">Current Password</label>
                        <input id="currentPassword" name="password" type="password" autocomplete="current-password" placeholder="Enter your current password">

                        <label for="newPassword">New Password</label>
                        <input id="newPassword" name="newPassword" type="password" autocomplete="new-password" placeholder="Leave empty if you do not want to change it">
                    </section>

                    <div class="actions">
                        <button class="btn-primary" type="submit">Save Manifest</button>
                        <button type="button" id="logout-button" class="btn-danger">Logout</button>
                    </div>
                </form>
            </section>
        </section>
    </main>
    <script src="/scripts/api.js"></script>
    <script src="/scripts/account-settings.js"></script>
</body>
</html>
