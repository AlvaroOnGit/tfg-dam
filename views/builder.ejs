<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="icon" href="/media/favicon.webp" type="image/webp">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Spellsword</title>
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/builder.css">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,600;0,6..72,700;1,6..72,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
</head>

<%- include('partials/notification') %>
<%- include('partials/asset-browser') %>

<body>
<header class="header-wrapper">
    <a href="/">
        <img class="logo-spellsword" src="/media/logo-spellsword.webp" alt="Spellsword Logo" title="Go to Mainpage">
    </a>
    <% if (user) { %>
        <div class="user-wrapper">
            <a href="/users/me" class="user-avatar" aria-label="Account settings" title="Go to profile">
                <% if (user.avatar) { %>
                    <img src="<%= user.avatar %>" alt="User Avatar">
                <% } else { %>
                    <img src="/media/avatar-default.webp" alt="User Avatar">
                <% } %>
            </a>
            <span class="user-avatar-name"><%= user.username || 'User' %></span>
        </div>
    <% } else { %>
        <a href="/auth" class="nav-item">Sign in</a>
    <% } %>
</header>
<hero >
    <div class="banner-wrapper">
        <img class="game-banner" src="/media/games/<%= game %>/graphics/<%= game %>-banner.webp" alt="Game Banner">
    </div>
    <div class="game-title-wrapper">
        <img src="/media/games/<%= game %>/graphics/<%= game %>-title.webp" alt="Game Title">
    </div>
</hero>
<%- include('partials/alert') %>

<main style="display: flex"
      data-game-slug="<%= game %>"
      data-is-owner="<%= isOwner %>"
        <% if (typeof build !== 'undefined' && build) { %>
            data-build-id="<%= build.id %>"
            data-build="<%= JSON.stringify(build) %>"
        <% } %>
>
    <%- include(`partials/builds/doll-${game}`) %>
    <section class="form-wrapper">
        <div class="form-header">
            <h2>Builder</h2>
        </div>
        <% if (typeof creator !== 'undefined' && creator) { %>
            <div class="form-group">
                <div class="form-label">Creator</div>
                <div class="user-wrapper">
                    <a href="/users/<%= creator.id %>" class="user-avatar" title="Go to profile">
                        <img src="/media/avatar-default.webp" alt="User Avatar">
                    </a>
                    <span class="user-avatar-name"><%= creator.username || 'User' %></span>
                </div>
            </div>
        <% } %>
        <div class="form-group">
            <div class="form-label">Build name</div>
            <input type="text" class="form-input" id="build-name"
                   placeholder="e.g. Crimson Vanguard" minlength="5"  maxlength="75"
             <%= !isOwner ? 'disabled' : '' %> />
            <div class="form-error" id="error-build-name" style="display:none"></div>
        </div>
        <div class="form-group">
            <div class="form-label">Description</div>
            <textarea class="form-textarea" id="build-desc"
                      placeholder="Describe your strategy, preferred playstyle…" minlength="1"
            <%= !isOwner ? 'disabled' : '' %>></textarea>
            <div class="form-error" id="error-build-desc" style="display:none"></div>
        </div>
        <div class="form-group">
            <div class="form-label">Tags <span class="tag-counter" id="tag-counter">(0/3)</span></div>
            <div class="tag-select" id="tag-select">
                <div class="tag-select__selected" id="tag-selected">
                    <span class="tag-select__placeholder">Select up to 3 tags…</span>
                </div>
                <button class="tag-select__trigger" id="tag-trigger">
                    <svg width="10" height="10" viewBox="0 0 10 10"><path d="M1 3l4 4 4-4" stroke="currentColor" stroke-width="1.2" fill="none"/></svg>
                </button>
                <div class="tag-select__dropdown" id="tag-dropdown"></div>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <div class="form-label">Game Version</div>
                <input type="text" class="form-input" id="build-game-version"
                       placeholder="e.g. 1.0.2"
                <%= !isOwner ? 'disabled' : '' %> />
                <div class="form-error" id="error-game-version" style="display:none">Format: 1.0 or 1.0.0</div>
            </div>
            <div class="form-group">
                <div class="form-label">Build Version</div>
                <input type="text" class="form-input" id="build-version"
                       placeholder="e.g. 1.0"
                <%= !isOwner ? 'disabled' : '' %> />
                <div class="form-error" id="error-build-version" style="display:none">Format: 1.0 or 1.0.0</div>
            </div>
        </div>
        <% if (isOwner) { %>
            <div class="form-group">
                <div class="form-label">Visibility</div>
                <div class="chip-group">
                    <button class="chip <%= (typeof build === 'undefined' || !build || build.isPublic) ? 'active' : '' %>" data-visibility="public">Public</button>
                    <button class="chip <%= (typeof build !== 'undefined' && build && !build.isPublic) ? 'active' : '' %>" data-visibility="private">Private</button>
                </div>
            </div>
        <% } %>
        <% if (isOwner) { %>
            <div class="form-actions">
                <div class="form-actions__row">
                    <a class="button primary" id="btn-save">Save Build</a>
                    <a class="button secondary" id="btn-discard">Discard</a>
                </div>
                <% if (typeof build !== 'undefined' && build) { %>
                    <a class="button danger" id="btn-delete">Delete Build</a>
                <% } %>
            </div>
        <% } %>
    </section>
</main>

<%- include('partials/footer') %>

<script src="/scripts/builder.js" type="module"></script>
</body>
</html>