<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="icon" href="/media/favicon.webp" type="image/webp">
    <meta charset="UTF-8">
    <title>Spellsword - Authentication</title>
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/auth.css">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;600&family=Newsreader:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
</head>

<%- include('partials/notification') %>

<body>

<header class="header-wrapper">
    <a href="/">
        <img class="logo-spellsword" src="/media/logo-spellsword.webp" alt="Spellsword Logo" title="Go to Mainpage">
    </a>
</header>

<%- include('partials/alert') %>

<main class="layout">
    <div class="auth-form-wrapper">
        <h2 class="auth-form-title">Login</h2>
        <div class="auth-form-alert success is-hidden">
            <span class="material-symbols-outlined">info</span>
            <p class="alert-message"></p>
        </div>
        <form class="auth-form">
            <div class="auth-username-wrapper is-hidden">
                <label for="auth-username">USERNAME</label>
                <input type="text" id="auth-username" name="username" minlength="3" maxlength="20">
            </div>

            <div class="auth-email-wrapper">
                <label for="auth-email">E-MAIL</label>
                <input type="email" id="auth-email" name="email">
            </div>

            <div class="auth-password-wrapper">
                <label for="auth-password">PASSWORD</label>
                <input type="password" id="auth-password" name="password" minlength="8" maxlength="64">
                <button type="button" class="auth-password-toggle">
                    <span class="material-symbols-outlined" title="Show Password">visibility</span>
                </button>
            </div>

            <a class="auth-forgot">Forgot Password?</a>

            <button type="submit" class="auth-submit">SIGN IN</button>
        </form>
        <div class="auth-toggle-wrapper">
            <p>Don't have an account?</p>
            <a style="cursor:pointer">Sign Up</a>
        </div>
    </div>
</main>
<%- include('partials/footer') %>
<script type="module" src="/scripts/auth.js"></script>
</body>
</html>