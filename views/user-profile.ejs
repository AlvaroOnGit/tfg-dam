<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Profile | Elden Scriptorium</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0">
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/account-settings.css">
    <link rel="stylesheet" href="/styles/user-profile.css">
</head>
<body>
    <div class="page-bg"></div>

    <header class="topbar">
        <a class="brand" href="/" aria-label="Elden Scriptorium">
            <img src="/media/logo-spellsword.webp" alt="Elden Scriptorium" class="logo-spellsword">
        </a>
        <nav class="top-nav">
            <a href="#">Builds</a>
            <a href="#">Lore</a>
            <a href="#">Grimoire</a>
            <a href="#">Almanac</a>
        </nav>
        <button class="icon-button" aria-label="Open user menu">
            <span class="material-symbols-outlined">account_circle</span>
        </button>
    </header>

    <main class="settings-shell">
        <p class="kicker">SANCTUM ACCESS</p>
        <h1>User Profile</h1>
        <p class="intro">
            Behold your legacy within the Scriptorium. Your deeds and discoveries are etched here.
        </p>

        <section class="settings-grid">
            <aside class="profile-panel">
                <div class="avatar-wrap">
                    <img src="/media/default-avatar.png" alt="User avatar" onerror="this.style.display='none'; this.parentElement.classList.add('avatar-fallback');">
                    <span class="avatar-placeholder"><%= user.username.charAt(0).toUpperCase() %></span>
                </div>

                <p class="quick-actions">Quick Actions</p>
                <a class="panel-link" href="/account/settings" style="text-decoration: none; display: block;">Edit Settings</a>
            </aside>

            <section class="form-panel" data-username="<%= user.username %>">
                <div class="panel-nav">
                    <a href="/user/settings" class="nav-btn">Settings</a>
                    <a href="/user/me" class="nav-btn active">Profile</a>
                </div>

                <p id="settings-message" class="form-message" aria-live="polite">
                    <span class="material-symbols-outlined" style="font-size: 18px;">info</span>
                    Welcome back, <%= user.username %>. This sanctum is currently under observation.
                </p>

                <section class="my-builds-section" aria-labelledby="my-builds-title">
                    <h2 id="my-builds-title" class="my-builds-title">My Builds</h2>
                    <div id="my-builds-list" class="my-builds-list" aria-live="polite">
                        <p class="my-builds-placeholder">Loading your builds...</p>
                    </div>
                </section>
            </section>
        </section>
    </main>
    <script src="/scripts/api.js"></script>
    <script src="/scripts/user-profile.js"></script>
</body>
</html>