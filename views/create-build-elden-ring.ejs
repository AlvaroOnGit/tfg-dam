<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Elden Ring Build — Spellsword</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400;1,6..72,500&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles/style.css" />
    <link rel="stylesheet" href="/styles/home.css" />
    <link rel="stylesheet" href="/styles/create-build.css" />
    <link rel="stylesheet" href="/styles/create-build-elden-ring.css" />
</head>
<body>

<header class="header-wrapper">
    <a href="/"><img class="logo-spellsword" src="/media/logo-spellsword.webp" alt="Spellsword Logo" title="Go to Mainpage"></a>
    <nav class="nav-wrapper">
        <a class="nav-item" href="#builds">Popular Builds</a>
        <a class="nav-item" href="<% if (user) { %>/user/settings?tab=builds<% } else { %>#builds<% } %>">My builds</a>
    </nav>
    <% if (user) { %>
        <div class="user-wrapper">
            <a href="/user/settings" class="user-avatar" aria-label="Account settings" title="Go to profile">
                <% if (user.avatar) { %><img src="<%= user.avatar %>" alt=""><% } else { %><%= user.username.slice(0, 2).toUpperCase() %><% } %>
            </a>
            <span class="user-avatar-name"><%= user.username || 'User' %></span>
        </div>
    <% } else { %>
        <a href="/auth" class="nav-item">Sign in</a>
    <% } %>
</header>

<div class="title-strip">
    <h1 class="title-strip__heading">Forge your Build</h1>
    <p class="title-strip__sub">Choose armor, weapons, talismans, spells and Ashes of War using Elden Ring assets.</p>
</div>

<main class="main-grid">
    <!-- ══════ LEFT COLUMN ══════ -->
    <aside>
        <div class="panel">
            <div class="section-title">❦ &nbsp; Inscription</div>
            <div class="form-group">
                <div class="form-label">Build name</div>
                <input type="text" class="form-input" id="build-name" maxlength="100" placeholder="e.g. Moonveil Battlemage" />
            </div>
            <div class="form-group">
                <div class="form-label">Description</div>
                <textarea class="form-textarea" id="build-desc" maxlength="500" placeholder="Core stats, combo route and gameplan"></textarea>
            </div>
            <div class="form-group">
                <div class="form-label">Visibility</div>
                <div class="chip-group">
                    <button class="chip active" data-visibility="public">Public</button>
                    <button class="chip" data-visibility="private">Private</button>
                </div>
            </div>
            <div class="form-group">
                <div class="form-label">Tags <span class="tag-counter" id="tag-counter">(0/3)</span></div>
                <div class="tag-select" id="tag-select">
                    <div class="tag-select__selected" id="tag-selected"><span class="tag-select__placeholder">Select up to 3 tags…</span></div>
                    <button class="tag-select__trigger" id="tag-trigger" onclick="toggleTagDropdown()">
                        <svg width="10" height="10" viewBox="0 0 10 10"><path d="M1 3l4 4 4-4" stroke="currentColor" stroke-width="1.2" fill="none"/></svg>
                    </button>
                    <div class="tag-select__dropdown" id="tag-dropdown"></div>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <div class="form-label">Game Version</div>
                    <input type="text" class="form-input" id="build-game-version" placeholder="e.g. 1.0.2" />
                    <div class="form-error" id="error-game-version" style="display:none">Format: 1.0 or 1.0.0</div>
                </div>
                <div class="form-group">
                    <div class="form-label">Build Version</div>
                    <input type="text" class="form-input" id="build-version" placeholder="e.g. 1.0" />
                    <div class="form-error" id="error-build-version" style="display:none">Format: 1.0 or 1.0.0</div>
                </div>
            </div>
            <div class="form-actions">
                <div class="form-actions__row">
                    <a class="button primary" id="btn-save">Save Build</a>
                    <a class="button secondary" id="btn-discard">Discard</a>
                </div>
                <a class="button danger" id="btn-delete">Delete Build</a>
            </div>
        </div>

        <div class="panel er-mid-panel er-mid-panel--spell">
            <div class="section-title">Spell Memory</div>
            <div id="spell-slots" class="er-grid"></div>
        </div>
    </aside>

    <!-- ══════ CENTER COLUMN ══════ -->
    <section class="center-stage">
        <div class="center-stage__grid">
            <div id="center-armor-labels" class="er-grid"></div>
            <div class="center-stage__character">
                <div class="center-stage__label">The Tarnished</div>
                <img class="center-stage__img" src="/media/games/elden-ring/graphics/doll-elden-ring.webp" alt="Elden Ring Character" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                <div class="center-stage__fallback" style="display:none;">
                    <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="0.8" opacity="0.25"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                    <span>Character image</span>
                </div>
                <div class="center-stage__glow"></div>
            </div>
            <div id="center-support-labels" class="er-grid"></div>
        </div>
        <div class="stats-bar stats-bar--elden">
            <div class="stats-bar__item"><div class="stats-bar__label">Armor</div><div class="stats-bar__value" id="stat-armor">0/4</div></div>
            <div class="stats-bar__item"><div class="stats-bar__label">Weapons</div><div class="stats-bar__value" id="stat-weapons">0/6</div></div>
            <div class="stats-bar__item"><div class="stats-bar__label">Talismans</div><div class="stats-bar__value" id="stat-talismans">0/4</div></div>
            <div class="stats-bar__item"><div class="stats-bar__label">Spells</div><div class="stats-bar__value" id="stat-spells">0/10</div></div>
        </div>
    </section>

    <!-- ══════ RIGHT COLUMN ══════ -->
    <aside class="summary-sidebar">
        <div class="panel">
            <div class="section-title">⚔ &nbsp; Weapon Loadouts</div>
            <div id="weapon-loadouts"></div>
        </div>
    </aside>
</main>

<%- include('partials/footer') %>

<!-- Delete confirmation modal -->
<div class="modal-overlay" id="delete-modal" style="display:none">
    <div class="modal">
        <div class="modal__icon">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="var(--color-error)" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/><path d="M12 7v6"/><circle cx="12" cy="16" r="0.5" fill="var(--color-error)"/>
            </svg>
        </div>
        <h3 class="modal__title">Delete Build</h3>
        <p class="modal__text">Are you sure you want to delete this build? This action cannot be undone.</p>
        <div class="modal__actions">
            <a class="button secondary" id="modal-cancel">Cancel</a>
            <a class="button danger" id="modal-confirm">Delete</a>
        </div>
    </div>
</div>

<script>
    // ================================================================
    // CONSTANTS & STATE
    // ================================================================
    const BUILD_ID = '<%= typeof buildId !== "undefined" && buildId ? buildId : "" %>';
    const IS_EDIT = !!BUILD_ID;
    const USER_ID = '<%= typeof user !== "undefined" && user ? user.id : "" %>';
    let IS_OWNER = !IS_EDIT;

    const API_BASE = '/api/assets?gameSlug=elden-ring';
    const MAX_TAGS = 3;
    const SEMVER_REGEX = /^\d+\.\d+(\.\d+)?$/;

    const ARMOR_SLOTS = [
        { key: 'helmet', label: 'Helmet', category: 'helmets', slotName: 'armor-0' },
        { key: 'chest', label: 'Chest', category: 'chest', slotName: 'armor-1' },
        { key: 'gauntlets', label: 'Gauntlets', category: 'gauntlets', slotName: 'armor-2' },
        { key: 'legs', label: 'Legs', category: 'legs', slotName: 'armor-3' },
    ];
    const TALISMAN_SLOTS = Array.from({ length: 4 }, (_, i) => ({ key: `talisman${i+1}`, label: `Talisman ${i+1}`, slotName: `talisman-${i}` }));
    const SPELL_SLOTS = Array.from({ length: 10 }, (_, i) => ({ key: `spell${i+1}`, label: `Spell ${i+1}`, slotName: `spell-${i}` }));
    const WEAPON_SLOTS = Array.from({ length: 6 }, (_, i) => ({ key: `weapon${i+1}`, label: `Weapon ${i+1}`, slotName: `weapon-${i}` }));
    const ASH_SLOTS = Array.from({ length: 6 }, (_, i) => `ashOfWar${i+1}`);

    const ALL_SLOTS = [...ARMOR_SLOTS, ...TALISMAN_SLOTS, ...SPELL_SLOTS, ...WEAPON_SLOTS];

    const SLOT_NAME_TO_KEY = {};
    ALL_SLOTS.forEach(s => { SLOT_NAME_TO_KEY[s.slotName] = s.key; });

    const state = {
        name: '', description: '', isPublic: true, tags: [], version: null, gameVersion: null,
        equipment: {},
        ashOfWar1: null, ashOfWar2: null, ashOfWar3: null,
        ashOfWar4: null, ashOfWar5: null, ashOfWar6: null,
    };
    ALL_SLOTS.forEach(slot => { state.equipment[slot.key] = null; });

    const ASSETS = { armor: [], weapon: [], talisman: [], spell: [], ash: [] };
    const LOADOUT_NAMES = ['Primary', 'Secondary', 'Tertiary'];

    const SLOT_ICONS = {
        helmet: `<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M4 16c0-5 3-11 8-12 5 1 8 7 8 12"/><path d="M4 16h16v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2z"/><path d="M8 16v-3c0-1.5 1.5-3 4-3s4 1.5 4 3v3"/></svg>`,
        chest: `<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M7 4c1.5 1 3 1.5 5 1.5S15.5 5 17 4l1 6c0 3-1 7-3 10H9C7 17 6 13 6 10z"/><path d="M9 10h6"/><path d="M10 14h4"/></svg>`,
        gauntlets: `<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M8 20V10l-2-2V5h12v3l-2 2v10z"/><path d="M8 10h8"/><path d="M8 14h8"/><path d="M10 5V3"/><path d="M14 5V3"/></svg>`,
        legs: `<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M8 3h8v6c0 3-1 6-2 9l-1 3h-2l-1-3c-1-3-2-6-2-9z"/><path d="M8 7h8"/><path d="M9 12h6"/></svg>`,
        talisman: `<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="12" cy="12" r="7"/><circle cx="12" cy="6" r="2.5"/></svg>`,
    };

    const ALL_TAGS = [
        { value: 'beginner-friendly', label: 'Beginner Friendly' },
        { value: 'endgame', label: 'Endgame' },
        { value: 'new-game-plus', label: 'New Game Plus' },
        { value: 'solo', label: 'Solo' },
        { value: 'co-op', label: 'Co-op' },
        { value: 'pvp', label: 'PvP' },
        { value: 'speedrun', label: 'Speedrun' },
        { value: 'tank', label: 'Tank' },
        { value: 'glass-cannon', label: 'Glass Cannon' },
        { value: 'faith-build', label: 'Faith Build' },
        { value: 'intelligence-build', label: 'Intelligence Build' },
        { value: 'arcane-build', label: 'Arcane Build' },
        { value: 'strength-build', label: 'Strength Build' },
        { value: 'dexterity-build', label: 'Dexterity Build' },
        { value: 'bleed', label: 'Bleed' },
        { value: 'poison', label: 'Poison' },
        { value: 'frost', label: 'Frost' },
        { value: 'magic-focused', label: 'Magic Focused' },
        { value: 'melee-focused', label: 'Melee Focused' },
        { value: 'ranged-focused', label: 'Ranged Focused' },
        { value: 'hybrid', label: 'Hybrid' },
        { value: 'min-maxed', label: 'Min-Maxed' },
        { value: 'budget', label: 'Budget' },
        { value: 'no-hit', label: 'No Hit' },
    ];

    function showToast(message) {
        const container = document.getElementById('toast-container');
        const text = document.getElementById('toast-text');

        if (!container || !text) return;

        text.innerText = message;
        container.style.display = 'block';
        container.style.animation = 'slideIn 0.3s ease-out';

        setTimeout(() => {
            container.style.animation = 'fadeOut 0.5s forwards';
            setTimeout(() => {
                container.style.display = 'none';
            }, 500);
        }, 3000);
    }

    // ================================================================
    // FETCH ASSETS
    // ================================================================
    async function fetchAssetsByType(type) {
        const items = []; let page = 1; let hasMore = true;
        while (hasMore) {
            const res = await fetch(`${API_BASE}&type=${type}&limit=50&page=${page}`);
            if (!res.ok) throw new Error(`Cannot load ${type}`);
            const data = await res.json();
            items.push(...data.assets); hasMore = items.length < data.total; page++;
        }
        return items;
    }

    async function loadAssets() {
        try {
            const [armor, weapon, talisman, spell, ash] = await Promise.all([
                fetchAssetsByType('armor'), fetchAssetsByType('weapon'),
                fetchAssetsByType('talisman'), fetchAssetsByType('spell'),
                fetchAssetsByType('ash-of-war'),
            ]);
            ASSETS.armor = armor; ASSETS.weapon = weapon;
            ASSETS.talisman = talisman; ASSETS.spell = spell; ASSETS.ash = ash;
        } catch (err) { console.warn(err.message); }
        renderAll();
    }

    function getAssetById(type, id) {
        if (!id) return null;
        return (ASSETS[type] || []).find(item => item.id === id) || null;
    }

    function parseAssetData(item) {
        if (!item || item.data == null) return {};
        const raw = item.data;
        if (typeof raw === 'string') { try { const o = JSON.parse(raw); return o && typeof o === 'object' ? o : {}; } catch { return {}; } }
        return typeof raw === 'object' ? raw : {};
    }

    function weaponAllowsAshOfWar(w) {
        if (!w) return false;
        return parseAssetData(w).compatible !== false;
    }

    // ================================================================
    // RENDER HELPERS
    // ================================================================
    function renderSlotBackgroundStyle(item) {
        if (!item || !item.iconUrl) return '';
        return `style="--slot-bg-image:url('${item.iconUrl}')"`;
    }

    function renderAssetIcon(item, fallbackSvg, imgClass) {
        if (!item || !item.iconUrl) return fallbackSvg;
        return `<img class="${imgClass}" src="${item.iconUrl}" alt="${item.name || 'Asset'}" loading="lazy" />`;
    }

    function renderTooltip(item) {
        if (!item) return '';
        const d = parseAssetData(item); let rows = '';

        // Attack (weapons)
        if (d.attack) {
            const a = d.attack;
            rows += `<div class="tooltip__section-label">Attack</div>`;
            if (a.physical) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Physical</span><span class="tooltip__stat-value">${a.physical}</span></div>`;
            if (a.magical) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Magical</span><span class="tooltip__stat-value">${a.magical}</span></div>`;
            if (a.fire) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Fire</span><span class="tooltip__stat-value">${a.fire}</span></div>`;
            if (a.lightning) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Lightning</span><span class="tooltip__stat-value">${a.lightning}</span></div>`;
            if (a.holy) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Holy</span><span class="tooltip__stat-value">${a.holy}</span></div>`;
            if (a.critical) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Critical</span><span class="tooltip__stat-value">${a.critical}</span></div>`;
        }

        // Negation (armor)
        if (d.negation) {
            const n = d.negation;
            rows += `<div class="tooltip__section-label">Damage Negation</div>`;
            if (n.physical != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Physical</span><span class="tooltip__stat-value">${n.physical}</span></div>`;
            if (n.strike != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Strike</span><span class="tooltip__stat-value">${n.strike}</span></div>`;
            if (n.slash != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Slash</span><span class="tooltip__stat-value">${n.slash}</span></div>`;
            if (n.pierce != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Pierce</span><span class="tooltip__stat-value">${n.pierce}</span></div>`;
            if (n.magical != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Magical</span><span class="tooltip__stat-value">${n.magical}</span></div>`;
            if (n.fire != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Fire</span><span class="tooltip__stat-value">${n.fire}</span></div>`;
            if (n.lightning != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Lightning</span><span class="tooltip__stat-value">${n.lightning}</span></div>`;
            if (n.holy != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Holy</span><span class="tooltip__stat-value">${n.holy}</span></div>`;
        }

        // Guard (weapons)
        if (d.guard) {
            const g = d.guard;
            rows += `<div class="tooltip__section-label">Guard</div>`;
            if (g.physical != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Guard Phys</span><span class="tooltip__stat-value">${g.physical}</span></div>`;
            if (g.magical != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Guard Mag</span><span class="tooltip__stat-value">${g.magical}</span></div>`;
            if (g.fire != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Guard Fire</span><span class="tooltip__stat-value">${g.fire}</span></div>`;
            if (g.lightning != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Guard Ltn</span><span class="tooltip__stat-value">${g.lightning}</span></div>`;
            if (g.holy != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Guard Holy</span><span class="tooltip__stat-value">${g.holy}</span></div>`;
            if (g.boost != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Boost</span><span class="tooltip__stat-value">${g.boost}</span></div>`;
        }

        // Resistance (armor)
        if (d.resistance) {
            rows += `<div class="tooltip__divider"></div>`;
            const r = d.resistance;
            if (r.immunity != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Immunity</span><span class="tooltip__stat-value">${r.immunity}</span></div>`;
            if (r.robustness != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Robustness</span><span class="tooltip__stat-value">${r.robustness}</span></div>`;
            if (r.focus != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Focus</span><span class="tooltip__stat-value">${r.focus}</span></div>`;
            if (r.vitality != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Vitality</span><span class="tooltip__stat-value">${r.vitality}</span></div>`;
            if (r.poise != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Poise</span><span class="tooltip__stat-value">${r.poise}</span></div>`;
        }

        // Scaling (weapons)
        if (d.scaling) {
            const entries = Object.entries(d.scaling).filter(([,v]) => v);
            if (entries.length) {
                rows += `<div class="tooltip__divider"></div>`;
                rows += `<div class="tooltip__row"><span class="tooltip__stat-label" style="font-weight:600">Scaling</span><span class="tooltip__stat-value"></span></div>`;
                entries.forEach(([k, v]) => { rows += `<div class="tooltip__row"><span class="tooltip__stat-label">${k}</span><span class="tooltip__stat-value tooltip__stat-value--magic">${v}</span></div>`; });
            }
        }

        // Requirements (weapons)
        if (d.requires) {
            const entries = Object.entries(d.requires).filter(([,v]) => v);
            if (entries.length) {
                rows += `<div class="tooltip__divider"></div>`;
                rows += `<div class="tooltip__row"><span class="tooltip__stat-label" style="font-weight:600">Requirements</span><span class="tooltip__stat-value"></span></div>`;
                entries.forEach(([k, v]) => { rows += `<div class="tooltip__row"><span class="tooltip__stat-label">${k}</span><span class="tooltip__stat-value">${v}</span></div>`; });
            }
        }

        // Skill
        if (d.skill) rows += `<div class="tooltip__divider"></div><div class="tooltip__row"><span class="tooltip__stat-label">Skill</span><span class="tooltip__stat-value tooltip__stat-value--magic">${d.skill}</span></div>`;

        // Damage types
        if (Array.isArray(d.damage) && d.damage.length && typeof d.damage[0] === 'string') {
            rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Damage Type</span><span class="tooltip__stat-value">${d.damage.join(', ')}</span></div>`;
        }

        // Spell fields
        if (d.fpCost != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">FP Cost</span><span class="tooltip__stat-value">${d.fpCost}</span></div>`;
        if (d.slots != null) rows += `<div class="tooltip__row"><span class="tooltip__stat-label">Slots</span><span class="tooltip__stat-value">${d.slots}</span></div>`;

        // Weight
        if (d.weight != null) rows += `<div class="tooltip__divider"></div><div class="tooltip__row"><span class="tooltip__stat-label">Weight</span><span class="tooltip__stat-value">${d.weight}</span></div>`;

        // Description
        const desc = item.shortDescription || item.description;
        if (desc) { rows += `<div class="tooltip__divider"></div><div class="tooltip__desc">${desc}</div>`; }
        if (!rows) return '';
        const typeLabel = item.type + (item.category ? ' · ' + item.category : '');
        return `<div class="tooltip"><div class="tooltip__header"><div class="tooltip__name">${item.name}</div><div class="tooltip__type">${typeLabel}</div></div><div class="tooltip__body">${rows}</div></div>`;
    }

    function renderAshTooltip(item) {
        if (!item) return '';
        const d = parseAssetData(item); let body = '';
        if (d.affinity) body += `<div class="tooltip__row"><span class="tooltip__stat-label">Affinity</span><span class="tooltip__stat-value tooltip__stat-value--magic">${d.affinity}</span></div>`;
        if (d.cost != null) body += `<div class="tooltip__row"><span class="tooltip__stat-label">Cost</span><span class="tooltip__stat-value">${d.cost}</span></div>`;
        const usable = Array.isArray(d.allowedWeapons) ? d.allowedWeapons.map(c => String(c).replace(/-/g,' ')).join(', ') : '';
        if (usable) { body += `<div class="tooltip__divider"></div><div class="tooltip__row" style="flex-direction:column;align-items:stretch;gap:4px;"><span class="tooltip__stat-label">Usable on</span><span class="tooltip__desc" style="font-style:normal;margin:0;line-height:1.4">${usable}</span></div>`; }
        const desc = item.shortDescription || item.description;
        if (desc) { body += `<div class="tooltip__divider"></div><div class="tooltip__desc">${desc}</div>`; }
        if (!body) body = `<div class="tooltip__desc" style="font-style:normal;">Stats unavailable.</div>`;
        return `<div class="tooltip"><div class="tooltip__header"><div class="tooltip__name">${item.name}</div><div class="tooltip__type">ash-of-war</div></div><div class="tooltip__body">${body}</div></div>`;
    }

    // ================================================================
    // RENDER FUNCTIONS
    // ================================================================
    function renderCenterSlot(containerId, slot, items, type, align) {
        const container = document.getElementById(containerId);
        const selected = getAssetById(type, state.equipment[slot.key]);
        const slotId = `${containerId}-${slot.key}`;
        const alignClass = align === 'right' ? 'center-equip--right' : 'center-equip--left';
        container.insertAdjacentHTML('beforeend', `
      <div class="center-equip ${alignClass}" id="${slotId}">
        <div class="center-equip__label">${slot.label}</div>
        <div class="has-tooltip">
          <button class="center-equip__trigger ${selected ? 'filled' : ''}" ${selected ? renderSlotBackgroundStyle(selected) : ''} onclick="toggleDropdown('${slotId}')">
            <span class="slot-icon">${renderAssetIcon(selected, type==='armor' ? (SLOT_ICONS[slot.key]||'') : SLOT_ICONS.talisman, 'center-equip__asset-icon')}</span>
            <span class="slot-text">${selected ? selected.name : 'empty'}</span>
          </button>
          ${selected ? renderTooltip(selected) : ''}
        </div>
        <div class="center-equip__dropdown" id="${slotId}-dropdown">
          <div class="equip-slot__dropdown-clear" onclick="pickSlot('${slot.key}', null)">✕ &nbsp; Clear slot</div>
          ${items.map(item => `<div class="equip-slot__dropdown-item" onclick="pickSlot('${slot.key}','${item.id}')"><div style="flex:1"><div class="item-name">${item.name}</div><span style="font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:var(--color-text-dim)">${item.type}${item.category ? ' · '+item.category : ''}</span></div></div>`).join('')}
          ${items.length === 0 ? '<div style="padding:12px;color:var(--color-text-dim);font-size:11px;text-align:center;">No assets loaded</div>' : ''}
        </div>
      </div>`);
    }

    function renderSlot(containerId, slot, items, type) {
        const container = document.getElementById(containerId);
        const selected = getAssetById(type, state.equipment[slot.key]);
        const slotId = `${containerId}-${slot.key}`;
        container.insertAdjacentHTML('beforeend', `
      <div class="mini-slot" id="${slotId}">
        <div class="has-tooltip">
          <button class="mini-slot__trigger" ${selected ? renderSlotBackgroundStyle(selected) : ''} onclick="toggleDropdown('${slotId}')">
            <span class="mini-slot__trigger-label">${selected ? '' : slot.label}</span>
            ${renderAssetIcon(selected, `<svg viewBox="0 0 24 24" width="20" height="20"><path d="M12 2l2 8 8 2-8 2-2 8-2-8-8-2 8-2z" fill="none" stroke="var(--color-primary)" stroke-width="1.3"/></svg>`, 'mini-slot__asset-icon')}
          </button>
          ${selected ? renderTooltip(selected) : ''}
        </div>
        <div class="mini-slot__name-below ${selected ? 'filled' : ''}">${selected ? selected.name : slot.label}</div>
        <div class="mini-slot__dropdown" id="${slotId}-dropdown">
          <div class="equip-slot__dropdown-clear" onclick="pickSlot('${slot.key}', null)">✕ &nbsp; Clear</div>
          ${items.map(item => `<div class="equip-slot__dropdown-item" onclick="pickSlot('${slot.key}','${item.id}')"><div style="flex:1"><div class="item-name">${item.name}</div><span style="font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:var(--color-text-dim)">${item.type}${item.category ? ' · '+item.category : ''}</span></div></div>`).join('')}
          ${items.length === 0 ? '<div style="padding:12px;color:var(--color-text-dim);font-size:11px;text-align:center;">No assets loaded</div>' : ''}
        </div>
      </div>`);
    }

    function getCompatibleAshes(weapon) {
        if (!weapon || !weaponAllowsAshOfWar(weapon)) return [];
        const byCategory = ASSETS.ash.filter(ash => { const ad = parseAssetData(ash); return Array.isArray(ad.allowedWeapons) && ad.allowedWeapons.includes(weapon.category); });
        return byCategory.length ? byCategory : ASSETS.ash;
    }

    function getAshSlotKeyForWeapon(slotKey) {
        const n = Number(slotKey.replace('weapon', ''));
        return (n >= 1 && n <= 6) ? ASH_SLOTS[n - 1] : null;
    }

    function renderWeaponAshPicker(slotKey, ashes, selectedAsh, weaponLabel) {
        const key = getAshSlotKeyForWeapon(slotKey);
        const slotId = `ash-${slotKey}`;
        return `
      <div class="form-label" style="margin-top:10px;">Ashes of War</div>
      <div class="relic-row" style="justify-content:flex-start;">
        <div class="relic-slot" id="${slotId}">
          <div class="has-tooltip has-tooltip--relic">
            <button class="relic-slot__trigger ${selectedAsh ? 'filled' : ''}" onclick="event.stopPropagation(); toggleAshDropdown('${slotId}')">
              <svg class="relic-slot__icon" viewBox="0 0 16 16" width="12" height="12"><path d="M8 1l1.5 4.5H14l-3.5 3 1.5 4.5L8 10l-4 3 1.5-4.5L2 5.5h4.5z" fill="none" stroke="${selectedAsh ? 'var(--color-rarity-epic)' : 'var(--color-text-dim)'}" stroke-width="1.2"/></svg>
              <span class="relic-slot__text">${selectedAsh ? selectedAsh.name : `Select Ash`}</span>
            </button>
            ${selectedAsh ? renderAshTooltip(selectedAsh) : ''}
          </div>
          <div class="relic-slot__dropdown" id="${slotId}-dropdown">
            <div class="equip-slot__dropdown-clear" onclick="event.stopPropagation(); pickAsh('${key}', null)">✕ &nbsp; Clear</div>
            ${ashes.map(item => `<div class="equip-slot__dropdown-item" onclick="event.stopPropagation(); pickAsh('${key}','${item.id}')"><div style="flex:1"><div class="item-name">${item.name}</div><span style="font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:var(--color-text-dim)">${item.data?.affinity || 'standard'} affinity</span></div></div>`).join('')}
            ${ashes.length === 0 ? '<div style="padding:12px;color:var(--color-text-dim);font-size:11px;text-align:center;">No compatible ashes</div>' : ''}
          </div>
        </div>
      </div>`;
    }

    function renderArmor() { document.getElementById('center-armor-labels').innerHTML = ''; ARMOR_SLOTS.forEach(s => renderCenterSlot('center-armor-labels', s, ASSETS.armor.filter(a => a.category === s.category), 'armor', 'right')); }
    function renderTalismans() { document.getElementById('center-support-labels').innerHTML = ''; TALISMAN_SLOTS.forEach(s => renderCenterSlot('center-support-labels', s, ASSETS.talisman, 'talisman', 'left')); }
    function renderSpells() { document.getElementById('spell-slots').innerHTML = ''; SPELL_SLOTS.forEach(s => renderSlot('spell-slots', s, ASSETS.spell, 'spell')); }

    function renderWeapons() {
        const container = document.getElementById('weapon-loadouts'); container.innerHTML = '';
        for (let i = 0; i < 3; i++) {
            const s1 = WEAPON_SLOTS[i*2], s2 = WEAPON_SLOTS[i*2+1];
            const sel1 = getAssetById('weapon', state.equipment[s1.key]), sel2 = getAssetById('weapon', state.equipment[s2.key]);
            const rAshes = getCompatibleAshes(sel1), lAshes = getCompatibleAshes(sel2);
            const rKey = getAshSlotKeyForWeapon(s1.key), lKey = getAshSlotKeyForWeapon(s2.key);
            const rAsh = getAssetById('ash', state[rKey]), lAsh = getAssetById('ash', state[lKey]);
            const rCompat = !!weaponAllowsAshOfWar(sel1), lCompat = !!weaponAllowsAshOfWar(sel2);
            const rValid = rAsh && rAshes.some(a => a.id === rAsh.id), lValid = lAsh && lAshes.some(a => a.id === lAsh.id);
            if (!rCompat || !rAshes.length || (rAsh && !rValid)) state[rKey] = null;
            if (!lCompat || !lAshes.length || (lAsh && !lValid)) state[lKey] = null;

            container.insertAdjacentHTML('beforeend', `
        <div class="weapon-loadout" id="loadout-${i}">
          <div class="weapon-loadout__header"><div class="form-label">Loadout ${i+1}</div><span class="weapon-loadout__label">${LOADOUT_NAMES[i]}</span></div>
          <div class="weapon-loadout__slots">
            <div>
              <div class="mini-slot" id="mini-${s1.key}">
                <div class="has-tooltip"><button class="mini-slot__trigger" ${sel1?renderSlotBackgroundStyle(sel1):''} onclick="toggleDropdown('mini-${s1.key}')"><span class="mini-slot__trigger-label">${sel1?'':'Right Hand'}</span>${renderAssetIcon(sel1,`<svg viewBox="0 0 24 24" width="20" height="20"><path d="M12 2l2 8 8 2-8 2-2 8-2-8-8-2 8-2z" fill="none" stroke="var(--color-primary)" stroke-width="1.3"/></svg>`,'mini-slot__asset-icon')}</button>${sel1?renderTooltip(sel1):''}</div>
                <div class="mini-slot__name-below ${sel1?'filled':''}">${sel1?sel1.name:'Right Hand'}</div>
                ${renderWeaponDropdown(s1.key, i)}
              </div>
              ${rCompat ? renderWeaponAshPicker(s1.key, rAshes, rValid ? rAsh : null, sel1?.name||'Right Hand') : ''}
            </div>
            <div>
              <div class="mini-slot" id="mini-${s2.key}">
                <div class="has-tooltip"><button class="mini-slot__trigger" ${sel2?renderSlotBackgroundStyle(sel2):''} onclick="toggleDropdown('mini-${s2.key}')"><span class="mini-slot__trigger-label">${sel2?'':'Left Hand'}</span>${renderAssetIcon(sel2,`<svg viewBox="0 0 24 24" width="20" height="20"><path d="M12 2l2 8 8 2-8 2-2 8-2-8-8-2 8-2z" fill="none" stroke="var(--color-primary)" stroke-width="1.3"/></svg>`,'mini-slot__asset-icon')}</button>${sel2?renderTooltip(sel2):''}</div>
                <div class="mini-slot__name-below ${sel2?'filled':''}">${sel2?sel2.name:'Left Hand'}</div>
                ${renderWeaponDropdown(s2.key, i)}
              </div>
              ${lCompat ? renderWeaponAshPicker(s2.key, lAshes, lValid ? lAsh : null, sel2?.name||'Left Hand') : ''}
            </div>
          </div>
        </div>`);
        }
    }

    function renderWeaponDropdown(slotKey, loadoutIndex) {
        const isLast = loadoutIndex === 2;
        const isLeft = slotKey.endsWith('1') || slotKey.endsWith('3') || slotKey.endsWith('5');
        const sideClass = isLast ? (isLeft ? 'mini-slot__dropdown--side-left' : 'mini-slot__dropdown--side-right') : '';
        return `<div class="mini-slot__dropdown ${sideClass}" id="mini-${slotKey}-dropdown"><div class="equip-slot__dropdown-clear" onclick="pickSlot('${slotKey}',null)">✕ &nbsp; Clear</div>${ASSETS.weapon.map(item=>`<div class="equip-slot__dropdown-item" onclick="pickSlot('${slotKey}','${item.id}')"><div style="flex:1"><div class="item-name">${item.name}</div><span style="font-size:9px;letter-spacing:0.15em;text-transform:uppercase;color:var(--color-text-dim)">${item.type}${item.category?' · '+item.category:''}</span></div></div>`).join('')}</div>`;
    }

    function renderAll() { renderArmor(); renderTalismans(); renderSpells(); renderWeapons(); updateStats(); renderTagSelector(); }

    function updateStats() {
        const count = slots => slots.filter(s => state.equipment[s.key]).length;
        document.getElementById('stat-armor').textContent = `${count(ARMOR_SLOTS)}/4`;
        document.getElementById('stat-weapons').textContent = `${count(WEAPON_SLOTS)}/6`;
        document.getElementById('stat-talismans').textContent = `${count(TALISMAN_SLOTS)}/4`;
        document.getElementById('stat-spells').textContent = `${count(SPELL_SLOTS)}/10`;
    }

    // ================================================================
    // INTERACTION HANDLERS
    // ================================================================
    function closeAllDropdowns() {
        document.querySelectorAll('.er-slot__dropdown.open,.center-equip__dropdown.open,.mini-slot__dropdown.open,.relic-slot__dropdown.open').forEach(d=>d.classList.remove('open'));
        document.querySelectorAll('.er-slot__trigger.open,.center-equip__trigger.open,.mini-slot__trigger.open,.relic-slot__trigger.open').forEach(t=>t.classList.remove('open'));
        document.querySelectorAll('.center-equip.dropdown-open').forEach(s=>s.classList.remove('dropdown-open'));
    }

    function toggleDropdown(slotId) {
        const dd = document.getElementById(`${slotId}-dropdown`);
        const tr = document.querySelector(`#${slotId} .center-equip__trigger`) || document.querySelector(`#${slotId} .mini-slot__trigger`);
        const cs = document.getElementById(slotId);
        const isOpen = dd?.classList.contains('open');
        closeAllDropdowns();
        if (!isOpen && dd) { dd.classList.add('open'); tr?.classList.add('open'); cs?.classList.add('dropdown-open'); }
    }

    function toggleAshDropdown(slotId) {
        const dd = document.getElementById(`${slotId}-dropdown`);
        const tr = document.querySelector(`#${slotId} .relic-slot__trigger`);
        const isOpen = dd?.classList.contains('open');
        closeAllDropdowns();
        if (!isOpen && dd) { dd.classList.add('open'); tr?.classList.add('open'); }
    }

    function pickSlot(slotKey, itemId) { state.equipment[slotKey] = itemId; closeAllDropdowns(); renderAll(); }
    function pickAsh(slotKey, itemId) { state[slotKey] = itemId; closeAllDropdowns(); renderAll(); }

    // ================================================================
    // TAG SELECTOR
    // ================================================================
    function toggleTagDropdown() { const d = document.getElementById('tag-dropdown'); const o = d.classList.contains('open'); closeAllDropdowns(); if (!o) d.classList.add('open'); }
    function addTag(v) { if (state.tags.length >= MAX_TAGS || state.tags.includes(v)) return; state.tags.push(v); renderTagSelector(); }
    function removeTag(v) { state.tags = state.tags.filter(t => t !== v); renderTagSelector(); }
    function renderTagSelector() {
        const sel = document.getElementById('tag-selected'), dd = document.getElementById('tag-dropdown');
        document.getElementById('tag-counter').textContent = `(${state.tags.length}/${MAX_TAGS})`;
        sel.innerHTML = state.tags.length ? state.tags.map(tag => { const l = ALL_TAGS.find(t=>t.value===tag)?.label||tag; return `<span class="tag-chip">${l}<button class="tag-chip__remove" onclick="event.stopPropagation();removeTag('${tag}')">×</button></span>`; }).join('') : '<span class="tag-select__placeholder">Select up to 3 tags…</span>';
        const avail = ALL_TAGS.filter(t => !state.tags.includes(t.value));
        dd.innerHTML = avail.map(t => `<div class="tag-select__option ${state.tags.length>=MAX_TAGS?'disabled':''}" onclick="${state.tags.length>=MAX_TAGS?'':`addTag('${t.value}')`}">${t.label}</div>`).join('');
        if (!avail.length) dd.innerHTML = '<div class="tag-select__option disabled">All tags selected</div>';
    }

    // ================================================================
    // LOAD BUILD (edit mode)
    // ================================================================
    async function loadBuild(buildId) {
        try {
            const res = await fetch(`/api/builds/${buildId}`);
            if (!res.ok) throw new Error('Build not found');
            const build = await res.json();

            state.name = build.name || '';
            state.description = build.description || '';
            state.isPublic = build.isPublic !== false;
            state.tags = build.tags || [];
            state.version = build.version || null;
            state.gameVersion = build.gameVersion || null;

            // Populate templateData (ashes of war)
            if (build.templateData) {
                ASH_SLOTS.forEach(key => { if (build.templateData[key]) state[key] = build.templateData[key]; });
            }

            // Populate assets into slots
            if (build.assets) {
                build.assets.forEach(asset => {
                    const slotKey = SLOT_NAME_TO_KEY[asset.slotName];
                    if (slotKey && state.equipment.hasOwnProperty(slotKey)) {
                        state.equipment[slotKey] = asset.id;
                    }
                });
            }

            // Update form fields
            document.getElementById('build-name').value = state.name;
            document.getElementById('build-desc').value = state.description;
            document.getElementById('build-game-version').value = state.gameVersion || '';
            document.getElementById('build-version').value = state.version || '';
            document.querySelectorAll('[data-visibility]').forEach(c => c.classList.remove('active'));
            document.querySelector(`[data-visibility="${state.isPublic ? 'public' : 'private'}"]`)?.classList.add('active');

            // Check ownership
            IS_OWNER = USER_ID && build.creatorId === USER_ID;
            if (!IS_OWNER) {
                document.querySelector('.title-strip__heading').textContent = 'View Build';
            } else {
                document.querySelector('.title-strip__heading').textContent = 'Edit Build';
            }

            renderAll();
            if (!IS_OWNER) lockForm();
        } catch (err) {
            console.error('Could not load build:', err.message);
        }
    }

    // ================================================================
    // LOCK FORM (non-owner view)
    // ================================================================
    function lockForm() {
        document.querySelectorAll('.form-input, .form-textarea').forEach(el => { el.disabled = true; el.style.opacity = '0.6'; el.style.cursor = 'default'; });
        document.querySelectorAll('.chip').forEach(el => { el.disabled = true; el.style.pointerEvents = 'none'; el.style.opacity = '0.6'; });
        const tt = document.getElementById('tag-trigger'); if (tt) { tt.disabled = true; tt.style.opacity = '0.6'; }
        document.querySelectorAll('.tag-chip__remove').forEach(el => el.style.display = 'none');
        document.querySelector('.form-actions').style.display = 'none';
        document.querySelectorAll('.center-equip__trigger, .mini-slot__trigger, .relic-slot__trigger').forEach(el => { el.style.pointerEvents = 'none'; });
    }

    // ================================================================
    // EVENT LISTENERS
    // ================================================================
    document.getElementById('build-name').addEventListener('input', e => { state.name = e.target.value; });
    document.getElementById('build-desc').addEventListener('input', e => { state.description = e.target.value; });

    function validateVersionField(inputId, errorId, stateKey) {
        const input = document.getElementById(inputId), error = document.getElementById(errorId);
        const val = input.value.trim();
        if (val && !SEMVER_REGEX.test(val)) { input.classList.add('error'); error.style.display = ''; state[stateKey] = null; }
        else { input.classList.remove('error'); error.style.display = 'none'; state[stateKey] = val || null; }
    }
    document.getElementById('build-game-version').addEventListener('input', () => validateVersionField('build-game-version', 'error-game-version', 'gameVersion'));
    document.getElementById('build-version').addEventListener('input', () => validateVersionField('build-version', 'error-build-version', 'version'));

    document.querySelectorAll('[data-visibility]').forEach(c => { c.addEventListener('click', () => { document.querySelectorAll('[data-visibility]').forEach(x => x.classList.remove('active')); c.classList.add('active'); state.isPublic = c.dataset.visibility === 'public'; }); });

    document.getElementById('btn-discard').addEventListener('click', () => {
        state.name = ''; state.description = ''; state.isPublic = true; state.tags = [];
        state.version = null; state.gameVersion = null;
        ASH_SLOTS.forEach(k => { state[k] = null; });
        ALL_SLOTS.forEach(s => { state.equipment[s.key] = null; });
        document.getElementById('build-name').value = '';
        document.getElementById('build-desc').value = '';
        document.getElementById('build-game-version').value = '';
        document.getElementById('build-version').value = '';
        document.querySelectorAll('[data-visibility]').forEach(c => c.classList.remove('active'));
        document.querySelector('[data-visibility="public"]')?.classList.add('active');
        closeAllDropdowns(); renderAll();
    });

    document.addEventListener('mousedown', e => {
        if (!e.target.closest('.center-equip') && !e.target.closest('.mini-slot') && !e.target.closest('.relic-slot') && !e.target.closest('#tag-select')) {
            closeAllDropdowns(); document.getElementById('tag-dropdown').classList.remove('open');
        }
    });

    // ================================================================
    // SAVE
    // ================================================================
    document.getElementById('btn-save').addEventListener('click', async () => {
        const ni = document.getElementById('build-name');
        const gvi = document.getElementById('build-game-version');
        const bvi = document.getElementById('build-version');
        let hasError = false;
        [ni, gvi, bvi].forEach(el => el.classList.remove('error'));
        document.getElementById('error-game-version').style.display = 'none';
        document.getElementById('error-build-version').style.display = 'none';

        if (!state.name.trim()) { ni.classList.add('error'); hasError = true; }
        if (!state.gameVersion || !SEMVER_REGEX.test(state.gameVersion)) { gvi.classList.add('error'); document.getElementById('error-game-version').style.display = ''; hasError = true; }
        if (!state.version || !SEMVER_REGEX.test(state.version)) { bvi.classList.add('error'); document.getElementById('error-build-version').style.display = ''; hasError = true; }
        if (hasError) { const first = document.querySelector('.form-input.error'); if (first) first.focus(); return; }

        function extractId(val) { return val && typeof val === 'object' ? val.id : (val || null); }

        const assets = [];
        ARMOR_SLOTS.forEach(s => { const id = extractId(state.equipment[s.key]); if (id) assets.push({ assetId: id, slotCategory: 'armor', slotName: s.slotName }); });
        WEAPON_SLOTS.forEach(s => { const id = extractId(state.equipment[s.key]); if (id) assets.push({ assetId: id, slotCategory: 'weapon', slotName: s.slotName }); });
        TALISMAN_SLOTS.forEach(s => { const id = extractId(state.equipment[s.key]); if (id) assets.push({ assetId: id, slotCategory: 'talisman', slotName: s.slotName }); });
        SPELL_SLOTS.forEach(s => { const id = extractId(state.equipment[s.key]); if (id) assets.push({ assetId: id, slotCategory: 'spell', slotName: s.slotName }); });

        const payload = {
            gameSlug: 'elden-ring',
            name: state.name,
            description: state.description || null,
            isPublic: state.isPublic,
            version: state.version,
            gameVersion: state.gameVersion,
            tags: state.tags,
            templateData: {
                ashOfWar1: extractId(state.ashOfWar1),
                ashOfWar2: extractId(state.ashOfWar2),
                ashOfWar3: extractId(state.ashOfWar3),
                ashOfWar4: extractId(state.ashOfWar4),
                ashOfWar5: extractId(state.ashOfWar5),
                ashOfWar6: extractId(state.ashOfWar6),
            },
            assets,
        };

        try {
            const url = IS_EDIT ? `/api/builds/${BUILD_ID}` : '/api/builds';
            const method = IS_EDIT ? 'PATCH' : 'POST';
            const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
            const data = await res.json();
            if (!res.ok) { console.error('Build save failed:', data);  showToast(data.message || 'Error saving build'); return; }
            if (IS_EDIT) {
                showToast('Build updated successfully!');
            } else {
                window.location.href = '/user/me';
            }
        } catch (err) { console.error('Network error:', err); alert('Could not connect to the server'); }
    });

    // ================================================================
    // INIT
    // ================================================================
    if (!IS_EDIT) {
        document.getElementById('btn-delete').style.display = 'none';
    } else {
        document.getElementById('btn-delete').addEventListener('click', () => {
            document.getElementById('delete-modal').style.display = 'flex';
        });
        document.getElementById('modal-cancel').addEventListener('click', () => {
            document.getElementById('delete-modal').style.display = 'none';
        });
        document.getElementById('delete-modal').addEventListener('click', (e) => {
            if (e.target === e.currentTarget) document.getElementById('delete-modal').style.display = 'none';
        });
        document.getElementById('modal-confirm').addEventListener('click', async () => {
            try {
                const res = await fetch(`/api/builds/${BUILD_ID}`, { method: 'DELETE' });
                if (!res.ok) { const data = await res.json(); alert(data.message || 'Error deleting build'); return; }
                window.location.href = '/user/me';
            } catch (err) { console.error('Network error:', err); alert('Could not connect to the server'); }
        });
    }

    renderTagSelector();
    loadAssets().then(() => { if (IS_EDIT) loadBuild(BUILD_ID); });
</script>
<div id="toast-container" class="toast-container">
    <div class="toast-message success">
        <span class="toast-icon">✓</span>
        <span id="toast-text">Build updated successfully!</span>
    </div>
</div>
</body>
</html>
